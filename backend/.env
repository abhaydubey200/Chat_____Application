# Dushman AI - Development Environment
# WARNING: NEVER commit this file to version control!
# This is for local development only.

# Security
JWT_SECRET=dev-secret-key-not-for-production-use-min-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database - Local PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/dushman_ai

# LLM Provider (nvidia or gemini)
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your-key-here
GEMINI_API_KEY=

# App
ENV=development
PROJECT_NAME=Dushman AI
API_V1_STR=/api
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Redis
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1

# Model Mappings (NVIDIA)
NVIDIA_MODEL_DEFAULT=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_FAST=meta/llama-3-8b-instruct
NVIDIA_MODEL_REASONING=nvidia/llama-3.1-nemotron-70b-instruct

# Model Mappings (Gemini)
GEMINI_MODEL_DEFAULT=gemini-1.5-flash
GEMINI_MODEL_FAST=gemini-1.5-flash
GEMINI_MODEL_REASONING=gemini-1.5-pro

# Governance & DLP
GOVERNANCE_ENABLED=true
DLP_ENTROPY_THRESHOLD=4.2
DLP_MIN_SECRET_LENGTH=16
DLP_MAX_MATCHES=20
DLP_DEFAULT_ACTION=warn
AUDIT_REDACT_CONTENT=true

# Retention
RETENTION_JOB_INTERVAL_MINUTES=60
RETENTION_DEFAULT_SOFT_DELETE_DAYS=30
RETENTION_DEFAULT_HARD_DELETE_DAYS=90

# Supabase SSL
SUPABASE_SSL_NO_VERIFY=false
