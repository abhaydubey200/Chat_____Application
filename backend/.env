# Dushman AI - Backend Environment Configuration

# ============================================================================
# ENVIRONMENT & APP SETTINGS
# ============================================================================

APP_ENV=development
PROJECT_NAME=Dushman AI

# ============================================================================
# SECURITY - JWT & AUTHENTICATION
# ============================================================================

JWT_SECRET=dushman-ai-super-secret-jwt-key-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/dushman_ai

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Active LLM provider: "nvidia" or "gemini"
LLM_PROVIDER=nvidia

# ---- NVIDIA API Configuration ----

# NVIDIA API Key
NVIDIA_API_KEY=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

# Model mappings for NVIDIA
NVIDIA_MODEL_DEFAULT=qwen/qwen3.5-122b-a10b
NVIDIA_MODEL_FAST=google/gemma-3n-e4b-it
NVIDIA_MODEL_REASONING=qwen/qwen3.5-122b-a10b

# ---- GEMINI API Configuration (Future Use) ----

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_DEFAULT=gemini-1.5-flash
GEMINI_MODEL_FAST=gemini-1.5-flash
GEMINI_MODEL_REASONING=gemini-1.5-pro

# ============================================================================
# CORS & FRONTEND CONFIGURATION
# ============================================================================

CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

DEBUG=true
