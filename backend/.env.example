# Dushman AI - Backend Environment Configuration
# Copy this file to .env and fill in with your actual values

# ============================================================================
# ENVIRONMENT & APP SETTINGS
# ============================================================================

# Deployment environment: 'development' or 'production'
# In production: docs disabled, stricter validation, CORS required
APP_ENV=development

# Project display name
PROJECT_NAME=Dushman AI

# ============================================================================
# SECURITY - JWT & AUTHENTICATION
# ============================================================================

# JWT secret key for signing tokens (MUST be >= 32 characters in production)
# Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required

# JWT algorithm (HS256 is standard)
JWT_ALGORITHM=HS256

# Access token expiration time in hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL async connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
# Example: postgresql+asyncpg://postgres:password@localhost:5432/dushman_ai
# Supabase: URL-encode special characters in password (SSL is enforced by the app)
# Example: postgresql+asyncpg://postgres:my%40pass@db.<project-id>.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/dushman_ai

# Optional: disable SSL verification if your network injects a self-signed cert
# (Use only if you see CERTIFICATE_VERIFY_FAILED)
# SUPABASE_SSL_NO_VERIFY=true

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Active LLM provider: "nvidia" or "gemini"
# Only the selected provider needs to be configured
LLM_PROVIDER=nvidia

# ---- NVIDIA API Configuration ----

# NVIDIA API Key (get from https://build.nvidia.com/endpoints)
# Format: nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# Model mappings for NVIDIA (default Llama 3.1 models)
NVIDIA_MODEL_DEFAULT=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_FAST=meta/llama-3-8b-instruct
NVIDIA_MODEL_REASONING=nvidia/llama-3.1-nemotron-70b-instruct

# ---- GEMINI API Configuration (Future Use) ----

# Google Gemini API Key (get from https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Model mappings for Gemini
GEMINI_MODEL_DEFAULT=gemini-1.5-flash
GEMINI_MODEL_FAST=gemini-1.5-flash
GEMINI_MODEL_REASONING=gemini-1.5-pro

# ============================================================================
# CORS & FRONTEND CONFIGURATION
# ============================================================================

# CORS allowed origins (comma-separated)
# In development: localhost:3000,localhost:3001
# In production: REQUIRED - must specify your frontend domain(s)
# Example: https://dushman-ai.com,https://app.dushman-ai.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Debug mode: "true" or "false"
# Enables verbose logging and SQL query output
DEBUG=true

# ============================================================================
# OPTIONAL: OBSERVABILITY & MONITORING
# ============================================================================

# Sentry error tracking (optional, for error monitoring)
# SENTRY_DSN=https://xxxxx@sentry.io/12345

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================

# For production deployment:
# 1. Change APP_ENV to "production"
# 2. Set JWT_SECRET to a strong random value (minimum 32 characters)
# 3. Configure CORS_ORIGINS to your frontend domain(s)
# 4. Use a proper PostgreSQL database (not localhost)
# 5. Configure appropriate LLM_PROVIDER with valid API key
# 6. Ensure DATABASE_URL uses secure SSL connection
# 7. Keep this file secure and never commit to version control
